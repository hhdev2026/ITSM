# Next.js (browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_DEMO_MODE=false
# Which RMM UI flow to use in the browser (meshcentral|netlock)
NEXT_PUBLIC_RMM_PROVIDER=meshcentral

# Express API / workers
PORT=4000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
CORS_ORIGIN=http://localhost:3000
ASSETS_WEBHOOK_SECRET=change-me-assets-secret

# Select which RMM provider to use for onboarding/sync (default: meshcentral)
RMM_PROVIDER=meshcentral

# Remote control (Guacamole + MeshCentral)
# - Run `docker compose up -d` to start `guacd` and `meshcentral` locally.
GUACD_HOST=127.0.0.1
GUACD_PORT=4822
# Generate secrets:
# - JWT secret: any random string (>= 32 chars)
# - Credentials key (AES-256): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
REMOTE_TUNNEL_JWT_SECRET=change-me-remote-tunnel-jwt-secret-32chars-min
REMOTE_TUNNEL_TOKEN_TTL_SECONDS=60
REMOTE_CREDENTIALS_KEY=change-me-base64-32-bytes

# MeshCentral (agent inventory sync -> assets)
# Used by `npm run dev:meshcentral-sync` (requires `meshcentral` installed).
MESHCENTRAL_URL=wss://localhost:4430
# Public URL shown to end-users in invite links (useful when MeshCentral is behind a port-map/reverse-proxy).
# Dev (docker-compose uses 4430): https://localhost:4430
# MESHCENTRAL_PUBLIC_URL=https://localhost:4430
MESHCENTRAL_USER=admin
MESHCENTRAL_PASS=change-me
# If your MeshCentral uses 2FA, set the current TOTP code when running a manual sync.
# MESHCENTRAL_TOKEN=123456
# Accept self-signed certs in dev (sets NODE_TLS_REJECT_UNAUTHORIZED=0 for meshctrl calls).
MESHCENTRAL_INSECURE_TLS=true
# Optional: only sync devices from one device group name (recommended).
MESHCENTRAL_DEVICEGROUP_NAME=TI
# Default department mapping in Supabase (for now, single department "TI").
MESHCENTRAL_DEFAULT_DEPARTMENT_NAME=TI
# How often to sync (worker loop).
MESHCENTRAL_SYNC_INTERVAL_MS=300000
# Only scan online devices (recommended).
MESHCENTRAL_ONLY_ONLINE=true

# NetLock RMM (self-hosted)
# File server (role "Files") base URL (used for installer generation + downloads).
# Example: https://rmm.yourdomain.com
NETLOCK_FILE_SERVER_URL=https://rmm.yourdomain.com
# API key for NetLock Files role (x-api-key header).
NETLOCK_FILE_SERVER_API_KEY=change-me-netlock-files-api-key
# Accept self-signed certs in dev (sets NODE_TLS_REJECT_UNAUTHORIZED=0).
NETLOCK_INSECURE_TLS=false

# One-click installer generation (server_config.json)
NETLOCK_SSL=true
NETLOCK_PACKAGE_GUID=11111111-1111-1111-1111-111111111111
NETLOCK_TENANT_GUID=11111111-1111-1111-1111-111111111111
NETLOCK_LOCATION_GUID=11111111-1111-1111-1111-111111111111
NETLOCK_LANGUAGE=es
NETLOCK_COMMUNICATION_SERVERS=rmm.yourdomain.com:7443
NETLOCK_REMOTE_SERVERS=rmm.yourdomain.com:7444
NETLOCK_UPDATE_SERVERS=rmm.yourdomain.com:7445
NETLOCK_TRUST_SERVERS=rmm.yourdomain.com:7446
NETLOCK_FILE_SERVERS=rmm.yourdomain.com:7447

# Ephemeral installer download tokens (required when RMM_PROVIDER=netlock)
RMM_INSTALLER_JWT_SECRET=change-me-rmm-installer-jwt-secret-32chars-min
RMM_INSTALLER_TOKEN_TTL_SECONDS=600

# Bootstrap superadmin (script)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_FULL_NAME=Super Admin
# SUPERADMIN_DEPARTMENT_ID=11111111-1111-1111-1111-111111111111
