# Next.js (browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_DEMO_MODE=false

# Express API / workers
NODE_ENV=development
PORT=4000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
CORS_ORIGIN=http://localhost:3000
# IMPORTANT (prod): usa un secreto largo (32+ chars, aleatorio) y rota si sospechas filtración.
ASSETS_WEBHOOK_SECRET=change-me-assets-secret-32chars-min
# Opcional: allowlist de IPs que pueden usar el webhook (separadas por coma).
# ASSETS_WEBHOOK_IP_ALLOWLIST=203.0.113.10,198.51.100.22
# Si estás detrás de un reverse proxy (Nginx/Traefik/Cloudflare), activa trust proxy.
TRUST_PROXY=false
# Base pública HTTPS de la API (evita host-header injection en links/instaladores).
# Requerido en prod si usas NetLock installer links.
# PUBLIC_API_BASE_URL=https://api.tu-dominio.cl
PUBLIC_API_BASE_URL=

# NetLock RMM (self-hosted)
# File server (role "Files") base URL (used for installer generation + downloads).
# Dev (docker-compose.yml): http://localhost:7080
NETLOCK_FILE_SERVER_URL=http://127.0.0.1:7080
# Prod (VM + Nginx + HTTPS):
# NETLOCK_FILE_SERVER_URL=https://netlock-files.<IP>.cloud-xip.com
# API key for NetLock Files role (x-api-key header).
NETLOCK_FILE_SERVER_API_KEY=change-me-netlock-files-api-key
# Accept self-signed certs in dev (sets NODE_TLS_REJECT_UNAUTHORIZED=0).
NETLOCK_INSECURE_TLS=false

# Optional: NetLock MySQL (recomendado en dev para detectar el equipo de forma confiable)
# Dev (docker-compose.yml): expone MySQL en 127.0.0.1:3307
NETLOCK_MYSQL_URL=mysql://root:netlock-dev@127.0.0.1:3307/netlock

# NetLock sync worker (pull inventory/telemetry -> Supabase)
NETLOCK_SYNC_ENABLED=true
NETLOCK_SYNC_INTERVAL_MS=300000
NETLOCK_SYNC_DEVICE_LIMIT=10000

# One-click installer generation (server_config.json)
NETLOCK_SSL=false
NETLOCK_PACKAGE_GUID=11111111-1111-1111-1111-111111111111
NETLOCK_TENANT_GUID=11111111-1111-1111-1111-111111111111
NETLOCK_LOCATION_GUID=11111111-1111-1111-1111-111111111111
NETLOCK_LANGUAGE=es
NETLOCK_COMMUNICATION_SERVERS=127.0.0.1:7080
NETLOCK_REMOTE_SERVERS=127.0.0.1:7080
NETLOCK_UPDATE_SERVERS=127.0.0.1:7080
NETLOCK_TRUST_SERVERS=127.0.0.1:7080
NETLOCK_FILE_SERVERS=127.0.0.1:7080
# Prod (VM + Nginx + HTTPS): usa 443 + SSL=true
# NETLOCK_SSL=true
# NETLOCK_COMMUNICATION_SERVERS=netlock-files.<IP>.cloud-xip.com:443
# NETLOCK_REMOTE_SERVERS=netlock-files.<IP>.cloud-xip.com:443
# NETLOCK_UPDATE_SERVERS=netlock-files.<IP>.cloud-xip.com:443
# NETLOCK_TRUST_SERVERS=netlock-files.<IP>.cloud-xip.com:443
# NETLOCK_FILE_SERVERS=netlock-files.<IP>.cloud-xip.com:443

# Ephemeral installer download tokens (download link shown to end-users)
RMM_INSTALLER_JWT_SECRET=change-me-rmm-installer-jwt-secret-32chars-min
RMM_INSTALLER_TOKEN_TTL_SECONDS=600

# NetLock Web Console (used in the chat "Tomar control" button)
NEXT_PUBLIC_NETLOCK_CONSOLE_URL=http://localhost:8080
# Prod:
# NEXT_PUBLIC_NETLOCK_CONSOLE_URL=https://netlock.<IP>.cloud-xip.com

# Bootstrap superadmin (script)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_FULL_NAME="Super Admin"
# SUPERADMIN_DEPARTMENT_ID=11111111-1111-1111-1111-111111111111
